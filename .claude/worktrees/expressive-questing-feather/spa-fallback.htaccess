# ─────────────────────────────────────────────────────────────
# SPA fallback for React Router (Sync Agency)
#
# Add this block to your EXISTING .htaccess at the site's document
# root on SiteGround. It lets client-side routes like /competition
# load directly (on refresh / shared link) instead of returning 404.
#
# How it works: real files and folders (assets, checkout.php, images,
# etc.) are served as-is; anything else is handed to index.html so
# React Router can resolve the route in the browser.
#
# Place it ABOVE any existing WordPress/other rewrite blocks, but
# below the "RewriteEngine On" line if one already exists (in that
# case, do NOT add a second RewriteEngine On — just add the rules).
# ─────────────────────────────────────────────────────────────

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite requests that map to a real file (e.g. checkout.php,
  # /assets/index-*.js, favicon, images) ...
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  # ... or a real directory.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else -> the SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>
